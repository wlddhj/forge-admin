<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.forge.modules.system.mapper.SysTenantPackageMenuMapper">

    <delete id="deleteByPackageId">
        DELETE FROM sys_tenant_package_menu WHERE tenant_package_id = #{packageId}
    </delete>

    <insert id="batchInsert">
        INSERT INTO sys_tenant_package_menu (tenant_package_id, menu_id) VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.tenantPackageId}, #{item.menuId})
        </foreach>
    </insert>

</mapper>
